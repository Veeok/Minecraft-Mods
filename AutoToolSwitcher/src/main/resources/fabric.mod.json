{
  "schemaVersion": 1,
  "id": "autotoolswitcher",
  "version": "${version}",
  "name": "Auto Tool Switcher",
  "description": "Client-side hotbar tool selection helper for Fabric. Includes Mod Menu settings, slot filters, durability safety, combat helpers, profiles, and slot restore.",
  "authors": [
    "Veok"
  ],
  "contact": {},
  "license": "MIT",
  "icon": "assets/autotoolswitcher/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.veok.autotoolswitcher.AutoToolSwitcherClient"
    ],
    "modmenu": [
      "com.veok.autotoolswitcher.AutoToolSwitcherModMenuIntegration"
    ]
  },
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": ">=26.1 <=26.2",
    "java": ">=25",
    "modmenu": ">=18.0.0-beta.1",
    "cloth-config": ">=26.1.154",
    "fabric-api": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.github": "https://github.com/Veeok/Minecraft-Mods"
      }
    }
  }
}
