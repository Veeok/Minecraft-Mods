  "authors": [
    "Veok"
  ],
  "contact": {},
  "license": "MIT",
  "icon": "assets/autotoolswitcher/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.veok.autotoolswitcher.AutoToolSwitcherClient"
    ]
  },
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "26.2",
    "java": ">=25",
    "fabric-api": "*"
  }
}
